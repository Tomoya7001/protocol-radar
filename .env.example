# protocol-radar environment

# REQUIRED. HMAC secret for the hash-chain ledger (F-002). The ledger deliberately
# refuses to append or verify without this set to a non-empty value, and the worker
# refuses to start without it. Use a long random value in production.
PROTOCOL_RADAR_HMAC_SECRET=

# Optional. SQLite database path. Default: ./data/protocol-radar.db
# Use ":memory:" for an ephemeral in-memory database (used by tests).
DATABASE_PATH=./data/protocol-radar.db
